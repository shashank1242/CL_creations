import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
#%%
df=pd.read_csv("businesses.csv")
df.head()
#%%
websites=df[df["website"].isnull()]
phones=df[df["phone"].notna()]
phones.head()


#%%
final_df=phones[phones["website"].isnull()]

final_df.to_csv("cleaned_data.csv",index=False)
#%%
# Clean and add + safely
final_df["phone"] = final_df["phone"].astype(str).str.replace(r"[^\d]", "", regex=True)  # strip everything except digits
final_df["phone"] = final_df["phone"].astype(str).str[:12]
final_df["phone"] = "+"+final_df["phone"]
final_df.to_csv("cleaned_data.csv",index=False)

